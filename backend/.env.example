# VPS Worker Configuration
VPS_PORT=3000
NODE_ENV=production

# Supabase Configuration
SUPABASE_URL=your_supabase_url
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Webhook Secret (Must match what you set in Supabase Edge Function env)
WEBHOOK_SECRET=your_long_random_secret

# Redis Configuration (For BullMQ)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Firebase Admin (For Push Notifications)
# You need to provide the path to your service account JSON file
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# Email Configuration (SendGrid)
SENDGRID_API_KEY=your_sendgrid_key
SYSTEM_EMAIL=noreply@notesnet.app
